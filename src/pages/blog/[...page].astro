---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import Pagination from '@/components/Pagination.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { POSTS_PER_PAGE } from '@/data/site';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);

  // Generate paths for page 1 (index), page 2, page 3, etc.
  const paths = [];

  // Page 1 (no page number in URL)
  paths.push({
    params: { page: undefined },
    props: {
      posts: sortedPosts.slice(0, POSTS_PER_PAGE),
      currentPage: 1,
      totalPages,
    },
  });

  // Pages 2+
  for (let i = 2; i <= totalPages; i++) {
    const start = (i - 1) * POSTS_PER_PAGE;
    paths.push({
      params: { page: i.toString() },
      props: {
        posts: sortedPosts.slice(start, start + POSTS_PER_PAGE),
        currentPage: i,
        totalPages,
      },
    });
  }

  return paths;
}

const { posts, currentPage, totalPages } = Astro.props;
const pageTitle = currentPage === 1
  ? 'Blog – Latest Articles & Trending Topics | Blog Worms'
  : `Blog – Page ${currentPage} | Blog Worms`;
const pageDescription = 'Browse all the latest trending blog posts, guides, and answers to unanswered questions from Blog Worms.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
>
  <div class="container-blog py-10 md:py-14">
    <Breadcrumbs items={[{ label: 'Blog', href: '/blog/' }]} />

    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-extrabold text-surface-900 mb-3">
        {currentPage === 1 ? 'Latest Blog Posts' : `Blog – Page ${currentPage}`}
      </h1>
      <p class="text-surface-600 max-w-xl mx-auto">
        Explore our latest articles covering trending topics, viral content, and questions that need answers.
      </p>
    </div>

    <BlogGrid posts={posts} />
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
  </div>
</BaseLayout>
