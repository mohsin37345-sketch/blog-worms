---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import FeaturedPosts from '@/components/FeaturedPosts.astro';
import BlogGrid from '@/components/BlogGrid.astro';
import Categories from '@/components/Categories.astro';
import WhyBlogWorms from '@/components/WhyBlogWorms.astro';
import FAQ from '@/components/FAQ.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'de' } },
    { params: { lang: 'ar' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const homeFaqs = [
  {
    question: t('faq.0.q'),
    answer: t('faq.0.a'),
  },
  {
    question: t('faq.1.q'),
    answer: t('faq.1.a'),
  },
  {
    question: t('faq.2.q'),
    answer: t('faq.2.a'),
  },
];
---

<BaseLayout
  title={t('home.hero.title')}
  description={t('home.hero.subtitle')}
  lang={lang}
>
  <Hero />
  <FeaturedPosts />
  <section class="section" id="latest-posts">
    <div class="container-blog">
      <BlogGrid posts={latestPosts} title={t('home.latest')} showAll={true} />
    </div>
  </section>
  <Categories />
  <WhyBlogWorms />
  <FAQ faqs={homeFaqs} title={t('home.faq.title')} />
</BaseLayout>
