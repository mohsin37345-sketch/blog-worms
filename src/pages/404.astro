---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 – Page Not Found | Blog Worms"
  description="Sorry, the page you're looking for doesn't exist or has been moved."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center max-w-lg mx-auto px-6">
      <!-- 404 Number -->
      <div class="text-8xl md:text-9xl font-black gradient-text mb-4 leading-none">
        404
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-surface-900 mb-4">
        Page Not Found
      </h1>

      <p class="text-surface-600 mb-8 leading-relaxed">
        Sorry, the page you're looking for doesn't exist or has been moved. Don't worry — there's plenty more to explore on Blog Worms.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary" id="404-home">
          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go Home
        </a>
        <a href="/blog/" class="btn-secondary" id="404-blog">
          Browse Blog
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
