---
---

<section class="relative overflow-hidden bg-grid-pattern" id="hero-section">
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-50/80 via-white/50 to-accent-50/60"></div>

  <!-- Decorative Blobs -->
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-200/30 rounded-full blur-3xl"></div>
  <div class="absolute -bottom-24 -left-24 w-80 h-80 bg-accent-200/20 rounded-full blur-3xl"></div>

  <div class="container-blog relative py-20 md:py-28 lg:py-32">
    <div class="max-w-3xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary-100/80 text-primary-700 text-sm font-medium mb-6 animate-[fade-in_0.5s_ease-out]">
        <span class="w-2 h-2 bg-primary-500 rounded-full animate-pulse"></span>
        Trending in the UK
      </div>

      <!-- H1 -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-surface-900 mb-6 text-balance animate-[slide-up_0.6s_ease-out]">
        Blog Worms – Latest
        <span class="gradient-text"> Viral & Trending</span>
        Blogs
      </h1>

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-surface-600 max-w-2xl mx-auto mb-10 leading-relaxed animate-[slide-up_0.7s_ease-out]">
        Your go-to source for <strong>trending topics</strong>, <strong>viral content</strong>, and <strong>unanswered questions</strong> from across the United Kingdom. We dig into what's buzzing so you don't have to.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center animate-[slide-up_0.8s_ease-out]">
        <a href="/blog/" class="btn-primary text-base px-8 py-3.5" id="hero-cta-blog">
          Explore Our Blog
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/about-us/" class="btn-secondary text-base px-8 py-3.5" id="hero-cta-about">
          Learn About Us
        </a>
      </div>

      <!-- Trust Indicators -->
      <div class="flex flex-wrap justify-center gap-6 mt-12 text-sm text-surface-500 animate-[fade-in_1s_ease-out]">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Free to read
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          Updated daily
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          UK focused
        </div>
      </div>
    </div>
  </div>
</section>
