---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <>
    {/* Mobile TOC — Collapsible */}
    <div class="lg:hidden mobile-toc" id="mobile-toc">
      <button
        class="mobile-toc-toggle"
        aria-expanded="false"
        id="mobile-toc-toggle"
      >
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          Table of Contents
        </span>
        <svg class="w-4 h-4 text-surface-400 transition-transform toc-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="mobile-toc-content" id="mobile-toc-content">
        <ul class="px-4 pb-4 space-y-1">
          {filteredHeadings.map((heading) => (
            <li class={heading.depth === 3 ? 'ml-4' : ''}>
              <a
                href={`#${heading.slug}`}
                class="block py-2 text-sm text-surface-600 active:text-primary-600 transition-colors leading-snug min-h-[40px] flex items-center"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Desktop TOC — Sticky sidebar */}
    <nav class="hidden lg:block bg-white rounded-xl border border-surface-200 p-5 sticky top-24" aria-label="Table of Contents" id="table-of-contents">
      <h2 class="text-sm font-bold text-surface-900 uppercase tracking-wider mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        Table of Contents
      </h2>
      <ul class="space-y-1.5 text-sm">
        {filteredHeadings.map((heading) => (
          <li class={heading.depth === 3 ? 'ml-4' : ''}>
            <a
              href={`#${heading.slug}`}
              class="block py-1 text-surface-600 hover:text-primary-600 transition-colors leading-snug"
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </>
)}

<script>
  // Mobile TOC toggle
  const tocToggle = document.getElementById('mobile-toc-toggle');
  const tocContent = document.getElementById('mobile-toc-content');
  const tocChevron = tocToggle?.querySelector('.toc-chevron');

  tocToggle?.addEventListener('click', () => {
    const isOpen = tocContent?.classList.contains('open');
    tocContent?.classList.toggle('open');
    tocChevron?.style.setProperty('transform', isOpen ? '' : 'rotate(180deg)');
    tocToggle.setAttribute('aria-expanded', (!isOpen).toString());
  });

  // Close TOC on link click (mobile)
  tocContent?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      tocContent.classList.remove('open');
      tocChevron?.style.setProperty('transform', '');
      tocToggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
