---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="bg-white rounded-xl border border-surface-200 p-5 sticky top-24" aria-label="Table of Contents" id="table-of-contents">
    <h2 class="text-sm font-bold text-surface-900 uppercase tracking-wider mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
      Table of Contents
    </h2>
    <ul class="space-y-1.5 text-sm">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? 'ml-4' : ''}>
          <a
            href={`#${heading.slug}`}
            class="block py-1 text-surface-600 hover:text-primary-600 transition-colors leading-snug"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
