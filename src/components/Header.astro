---
import { NAV_LINKS, SITE } from '@/data/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-lg border-b border-surface-200/50 safe-top" id="site-header">
  <nav class="container-blog flex items-center justify-between h-14 md:h-16" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group min-h-[44px]" id="site-logo">
      <img
        src="/images/blog-worms-logo.png"
        alt="Blog Worms Logo"
        width="48"
        height="48"
        class="w-12 h-12 md:w-[52px] md:h-[52px] rounded-xl transition-transform group-hover:scale-110"
      />
      <span class="text-lg font-extrabold tracking-tight" style="letter-spacing: -0.02em;">
        <span style="color: #1e3a8a;">Blog</span><span style="color: #dc2626;">Worms</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-1">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 min-h-[44px] flex items-center ${
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-primary-600 bg-primary-50'
              : 'text-surface-600 hover:text-primary-600 hover:bg-surface-100'
          }`}
          id={`nav-${link.label.toLowerCase().replace(/\s/g, '-')}`}
        >
          {link.label}
        </a>
      ))}
      <LanguageSwitcher />
    </div>

    <!-- Mobile Menu Button — 48x48 touch target -->
    <button
      class="md:hidden flex items-center justify-center w-12 h-12 -mr-2 rounded-xl text-surface-700 active:bg-surface-100 transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="mobile-menu-btn"
    >
      <svg class="w-6 h-6 menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg class="w-6 h-6 close-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu — Full screen overlay -->
  <div
    class="md:hidden hidden mobile-menu-overlay"
    id="mobile-menu"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <div class="container-blog py-6 space-y-1">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class={`flex items-center px-4 py-4 rounded-xl text-base font-semibold transition-colors min-h-[52px] ${
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-primary-600 bg-primary-50'
              : 'text-surface-700 active:bg-surface-100'
          }`}
        >
          {link.label}
        </a>
      ))}

      <!-- Divider -->
      <div class="border-t border-surface-200 my-4 !mt-6"></div>

      <!-- Language Selector in mobile menu -->
      <div class="px-4 pt-2">
        <p class="text-xs font-semibold text-surface-400 uppercase tracking-wider mb-3">Language</p>
        <LanguageSwitcher />
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuBtn?.querySelector('.menu-icon');
  const closeIcon = menuBtn?.querySelector('.close-icon');
  const body = document.body;

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;

    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.setAttribute('aria-label', 'Open menu');
      body.classList.remove('menu-open');
    } else {
      mobileMenu?.classList.remove('hidden');
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.setAttribute('aria-label', 'Close menu');
      body.classList.add('menu-open');
    }
  });

  // Close on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      body.classList.remove('menu-open');
    });
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      mobileMenu?.classList.add('hidden');
      menuIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      body.classList.remove('menu-open');
    }
  });
</script>
