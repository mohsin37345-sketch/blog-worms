---
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;
const siteUrl = 'https://blogworms.co.uk';
const fullUrl = url.startsWith('http') ? url : `${siteUrl}${url}`;
const encodedUrl = encodeURIComponent(fullUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = [
  {
    name: 'Twitter',
    href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
    icon: 'twitter',
    color: 'hover:bg-[#1DA1F2] active:bg-[#1DA1F2] hover:text-white active:text-white',
  },
  {
    name: 'Pinterest',
    href: `https://pinterest.com/pin/create/button/?url=${encodedUrl}&description=${encodedTitle}`,
    icon: 'pinterest',
    color: 'hover:bg-[#E60023] active:bg-[#E60023] hover:text-white active:text-white',
  },
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}`,
    icon: 'linkedin',
    color: 'hover:bg-[#0A66C2] active:bg-[#0A66C2] hover:text-white active:text-white',
  },
  {
    name: 'WhatsApp',
    href: `https://wa.me/?text=${encodedTitle}%20${encodedUrl}`,
    icon: 'whatsapp',
    color: 'hover:bg-[#25D366] active:bg-[#25D366] hover:text-white active:text-white',
  },
];
---

<div class="flex items-center gap-2 sm:gap-3 flex-wrap" id="social-share">
  <span class="text-sm font-semibold text-surface-700">Share:</span>
  <div class="flex gap-1.5 sm:gap-2">
    {shareLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class={`w-10 h-10 sm:w-9 sm:h-9 rounded-lg bg-surface-100 text-surface-600 flex items-center justify-center transition-all duration-200 ${link.color}`}
        aria-label={`Share on ${link.name}`}
        id={`share-${link.icon}`}
      >
        {link.icon === 'twitter' && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        )}
        {link.icon === 'pinterest' && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0a12 12 0 00-4.373 23.178c-.07-.937-.134-2.377.028-3.401.146-.926.943-5.893.943-5.893s-.24-.482-.24-1.192c0-1.118.648-1.953 1.455-1.953.687 0 1.018.515 1.018 1.134 0 .69-.44 1.723-.667 2.68-.19.803.402 1.457 1.192 1.457 1.43 0 2.529-1.508 2.529-3.683 0-1.926-1.384-3.27-3.361-3.27-2.289 0-3.633 1.717-3.633 3.493 0 .691.266 1.432.599 1.835a.24.24 0 01.056.23c-.061.255-.197.803-.224.916-.035.148-.116.18-.268.108-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-.811 0-1.573-.421-1.834-.919l-.498 1.902c-.181.695-.669 1.566-.995 2.097A12 12 0 1012 0z"/></svg>
        )}
        {link.icon === 'linkedin' && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        )}
        {link.icon === 'whatsapp' && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        )}
      </a>
    ))}
  </div>
</div>
