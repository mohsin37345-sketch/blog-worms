---
import { NAV_LINKS, LEGAL_LINKS, SOCIAL_LINKS, SITE } from '@/data/site';

const year = new Date().getFullYear();
---

<footer class="bg-surface-900 text-surface-300 mt-auto safe-bottom">
  <!-- Main Footer -->
  <div class="container-blog py-10 sm:py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10">
      <!-- Brand Column -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img
            src="/images/blog-worms-logo.webp"
            alt="Blog Worms"
            width="48"
            height="48"
            class="w-12 h-12 md:w-[52px] md:h-[52px] rounded-xl"
          />
          <span class="text-lg font-extrabold" style="letter-spacing: -0.02em;">
            <span style="color: #93b4ff;">Blog</span><span style="color: #f87171;">Worms</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed text-surface-400 mb-6">
          {SITE.description}
        </p>
        <!-- Social Icons -->
        <div class="flex gap-2.5">
          {SOCIAL_LINKS.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-11 h-11 sm:w-9 sm:h-9 rounded-lg bg-surface-800 active:bg-primary-600 hover:bg-primary-600 flex items-center justify-center transition-all duration-200"
              aria-label={`Follow us on ${social.label}`}
              id={`footer-social-${social.icon}`}
            >
              {social.icon === 'twitter' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              )}
              {social.icon === 'pinterest' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0a12 12 0 00-4.373 23.178c-.07-.937-.134-2.377.028-3.401.146-.926.943-5.893.943-5.893s-.24-.482-.24-1.192c0-1.118.648-1.953 1.455-1.953.687 0 1.018.515 1.018 1.134 0 .69-.44 1.723-.667 2.68-.19.803.402 1.457 1.192 1.457 1.43 0 2.529-1.508 2.529-3.683 0-1.926-1.384-3.27-3.361-3.27-2.289 0-3.633 1.717-3.633 3.493 0 .691.266 1.432.599 1.835a.24.24 0 01.056.23c-.061.255-.197.803-.224.916-.035.148-.116.18-.268.108-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-.811 0-1.573-.421-1.834-.919l-.498 1.902c-.181.695-.669 1.566-.995 2.097A12 12 0 1012 0z"/></svg>
              )}
              {social.icon === 'youtube' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-surface-400 active:text-primary-400 hover:text-primary-400 transition-colors inline-flex items-center min-h-[40px]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {LEGAL_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-surface-400 active:text-primary-400 hover:text-primary-400 transition-colors inline-flex items-center min-h-[40px]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter / CTA -->
      <div class="col-span-2 lg:col-span-1">
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Stay Updated</h3>
        <p class="text-sm text-surface-400 mb-4">
          Get the latest trending content delivered to your inbox. No spam, only the good stuff.
        </p>
        <a href="/blog/" class="btn-primary text-sm !py-2.5 !px-5">
          Browse Latest Posts
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-surface-800">
    <div class="container-blog py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-surface-500">
      <p>&copy; {year} Blog Worms. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a
          href="/sitemap/"
          class="text-surface-400 hover:text-primary-400 transition-colors"
          id="footer-html-sitemap"
        >
          Sitemap
        </a>
        <span class="text-surface-700">|</span>
        <a
          href="/sitemap-index.xml"
          class="text-surface-400 hover:text-primary-400 transition-colors"
          id="footer-xml-sitemap"
        >
          XML Sitemap
        </a>
        <span class="text-surface-700">|</span>
        <p>Built by Mohsin Mughal.</p>
      </div>
    </div>
  </div>
</footer>
