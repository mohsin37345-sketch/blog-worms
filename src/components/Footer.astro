---
import { NAV_LINKS, LEGAL_LINKS, SOCIAL_LINKS, SITE } from '@/data/site';

const year = new Date().getFullYear();
---

<footer class="bg-surface-900 text-surface-300 mt-auto">
  <!-- Main Footer -->
  <div class="container-blog py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <img
            src="/images/blog-worms-logo.png"
            alt="Blog Worms"
            width="32"
            height="32"
            class="rounded-lg"
          />
          <span class="text-lg font-extrabold text-white">
            Blog<span class="text-primary-400">Worms</span>
          </span>
        </a>
        <p class="text-sm leading-relaxed text-surface-400 mb-6">
          {SITE.description}
        </p>
        <!-- Social Icons -->
        <div class="flex gap-3">
          {SOCIAL_LINKS.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-lg bg-surface-800 hover:bg-primary-600 flex items-center justify-center transition-all duration-200 hover:-translate-y-0.5"
              aria-label={`Follow us on ${social.label}`}
              id={`footer-social-${social.icon}`}
            >
              {social.icon === 'twitter' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              )}
              {social.icon === 'facebook' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              )}
              {social.icon === 'linkedin' && (
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-surface-400 hover:text-primary-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal Links -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {LEGAL_LINKS.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-surface-400 hover:text-primary-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Newsletter / CTA -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Stay Updated</h3>
        <p class="text-sm text-surface-400 mb-4">
          Get the latest trending content delivered to your inbox. No spam, only the good stuff.
        </p>
        <a href="/blog/" class="btn-primary text-sm !py-2.5 !px-5">
          Browse Latest Posts
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-surface-800">
    <div class="container-blog py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-surface-500">
      <p>&copy; {year} Blog Worms. All rights reserved.</p>
      <p>Built for speed, SEO, and great content.</p>
    </div>
  </div>
</footer>
