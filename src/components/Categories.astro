---
import { CATEGORIES } from '@/data/site';
---

<section class="section section-alt" id="categories-section">
  <div class="container-blog">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-surface-900">Browse by Category</h2>
      <p class="text-surface-600 mt-3 max-w-xl mx-auto">
        Explore our content organised by topic. Find exactly what you're looking for.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
      {CATEGORIES.map((cat) => (
        <a
          href={`/blog/?category=${cat.slug}`}
          class="card group p-8 text-center hover:border-primary-200 border-2 border-transparent transition-all"
          id={`category-${cat.slug}`}
        >
          <div class="text-4xl mb-4 group-hover:scale-110 transition-transform">
            {cat.icon}
          </div>
          <h3 class="text-xl font-bold text-surface-900 mb-2 group-hover:text-primary-600 transition-colors">
            {cat.name}
          </h3>
          <p class="text-sm text-surface-600 leading-relaxed">
            {cat.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
