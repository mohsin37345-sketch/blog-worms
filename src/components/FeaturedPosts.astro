---
import BlogCard from './BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featuredPosts = allPosts
  .filter((post) => post.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// If not enough featured, fill from latest
const displayPosts = featuredPosts.length >= 1
  ? featuredPosts
  : allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

{displayPosts.length > 0 && (
  <section class="section" id="featured-posts">
    <div class="container-blog">
      <div class="text-center mb-10">
        <span class="badge mb-3">⭐ Editor's Picks</span>
        <h2 class="text-2xl md:text-3xl font-bold text-surface-900">Featured Articles</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {displayPosts.map((post, i) => (
          <BlogCard
            slug={post.id}
            title={post.data.title}
            description={post.data.description}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            date={post.data.date}
            category={post.data.category}
            author={post.data.author}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>
)}
